// HSI Sales AI Platform — Prisma Schema
// Covers Phase 1 (core entities for Module 1). Future modules will extend this schema.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============== Core ===============

model User {
  id           String     @id @default(cuid())
  name         String
  email        String     @unique
  passwordHash String
  role         String     @default("sales") // sales | admin
  createdAt    DateTime   @default(now())

  accounts  Account[]
  deals     Deal[]
  activities Activity[]
  meetings   Meeting[]
  aiLogs     AILog[]
}

model Account {
  id          String   @id @default(cuid())
  companyName String
  industry    String?
  size        String?  // SMB | mid-market | enterprise
  website     String?
  address     String?
  notes       String?  @db.Text
  healthScore Int?     @default(50)
  ownerId     String
  owner       User     @relation(fields: [ownerId], references: [id])

  contacts   Contact[]
  deals      Deal[]
  activities Activity[]
  insights   CRMInsight[]
  healthSnapshots HealthSnapshot[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Contact {
  id        String  @id @default(cuid())
  fullName  String
  title     String?
  email     String?
  phone     String?
  isPrimary Boolean @default(false)
  accountId String
  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model Deal {
  id            String    @id @default(cuid())
  title         String
  value         Float?
  stage         String    // prospecting | qualification | proposal | negotiation | closed_won | closed_lost
  probability   Int?
  expectedClose DateTime?
  vendor        String?   // HPE | Dell | IBM | Palo Alto | CrowdStrike | Microsoft
  productLine   String?   // server | storage | networking | security | cloud | software
  winReason     String?
  lossReason    String?
  competitorId  String?

  accountId String
  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  ownerId   String
  owner     User    @relation(fields: [ownerId], references: [id])

  activities Activity[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([stage])
  @@index([accountId])
}

model Activity {
  id        String    @id @default(cuid())
  type      String    // email | call | meeting | note | follow_up
  subject   String
  content   String?   @db.Text
  dueDate   DateTime?
  completed Boolean   @default(false)

  dealId    String?
  deal      Deal?    @relation(fields: [dealId], references: [id], onDelete: SetNull)
  accountId String?
  account   Account? @relation(fields: [accountId], references: [id], onDelete: SetNull)
  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id])

  createdAt DateTime @default(now())

  @@index([accountId])
  @@index([dealId])
}

model CRMInsight {
  id          String   @id @default(cuid())
  accountId   String
  account     Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  type        String   // next_action | risk_alert | opportunity
  content     String   @db.Text
  priority    String   // high | medium | low
  status      String   @default("pending") // pending | acted | dismissed
  generatedAt DateTime @default(now())

  @@index([accountId])
}

// =============== AI ===============

model AILog {
  id        String   @id @default(cuid())
  module    String
  prompt    String   @db.Text
  response  String   @db.Text
  tokenIn   Int
  tokenOut  Int
  latencyMs Int
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

// =============== Meetings (Phase 2 placeholder, schema now so we don't churn later) ===============

model Meeting {
  id         String       @id @default(cuid())
  title      String
  date       DateTime
  attendees  String
  rawNotes   String       @db.Text
  aiSummary  String?      @db.Text
  accountId  String?
  dealId     String?
  ownerId    String
  owner      User         @relation(fields: [ownerId], references: [id])
  actionItems ActionItem[]
  createdAt  DateTime     @default(now())
}

model ActionItem {
  id        String    @id @default(cuid())
  content   String
  assignee  String?
  dueDate   DateTime?
  status    String    @default("pending")
  meetingId String
  meeting   Meeting   @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([status])
}

// =============== Email Composer (Module 9) ===============

model EmailDraft {
  id        String   @id @default(cuid())
  type      String   // cold_outreach | follow_up | thank_you | introduction | proposal_send | meeting_request | check_in
  language  String   @default("vi") // vi | en
  subject   String
  body      String   @db.Text
  tone      String   @default("professional") // professional | friendly | formal | urgent
  status    String   @default("draft") // draft | sent | failed
  sentAt    DateTime?
  sentTo    String?  // recipient email at send time
  sendError String?  @db.Text
  accountId String?
  dealId    String?
  contactId String?
  ownerId   String
  createdAt DateTime @default(now())

  @@index([ownerId, createdAt])
}

model EmailTemplate {
  id       String @id @default(cuid())
  name     String
  type     String
  language String
  subject  String
  body     String @db.Text
}

// =============== Daily Briefing (Module 11) ===============

model DailyBriefing {
  id        String   @id @default(cuid())
  date      DateTime
  userId    String
  content   String   @db.Text
  sections  Json
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@unique([userId, date])
  @@index([userId, date])
}

// =============== Proposals (Module 4) ===============

model Proposal {
  id        String   @id @default(cuid())
  title     String
  status    String   @default("draft") // draft | ready | sent | accepted | rejected
  language  String   @default("vi")
  version   Int      @default(1)
  accountId String?
  dealId    String?
  ownerId   String
  // sections: Array<{ id, heading, body, order }>
  sections  Json     @default("[]")
  // inputs: { clientName, industry, requirements, valueProps, timeline, budget, vendors[] }
  inputs    Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId, createdAt])
}

// =============== Quotations + Products (Module 5) ===============

model Product {
  id          String   @id @default(cuid())
  vendor      String   // HPE | Dell | IBM | Palo Alto | CrowdStrike | Microsoft | Other
  sku         String?
  name        String
  description String?  @db.Text
  category    String?  // server | storage | networking | security | cloud | software | service
  unit        String   @default("unit") // unit | license | month | year
  listPrice   Float    @default(0)
  partnerCost Float?
  currency    String   @default("VND")
  active      Boolean  @default(true)
  // Semantic search embedding. Nullable — legacy products without backfill still work
  // and chat-ai falls back to keyword match. Vector is ~384-dim Float[], stored as Json.
  embedding   Json?
  embeddedAt  DateTime?
  createdAt   DateTime @default(now())

  @@index([vendor])
  @@index([category])
}

// =============== Health Snapshots (Module 2) ===============

model HealthSnapshot {
  id          String   @id @default(cuid())
  accountId   String
  account     Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  score       Int
  riskLevel   String   // healthy | watch | at_risk | critical
  factors     Json
  explanation String   @db.Text
  createdAt   DateTime @default(now())

  @@index([accountId, createdAt])
}

// =============== Sales Reports (Module 12) ===============

model SalesReport {
  id        String   @id @default(cuid())
  userId    String
  title     String
  period    String   // week | month | quarter | custom
  startDate DateTime
  endDate   DateTime
  content   String   @db.Text
  sections  Json
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

// =============== Win/Loss Reports (Module 13) ===============

model WinLossReport {
  id         String   @id @default(cuid())
  userId     String
  title      String
  filters    Json
  metrics    Json
  aiInsights String   @db.Text
  createdAt  DateTime @default(now())

  @@index([userId, createdAt])
}

// =============== RFP Response (Module 6) ===============

model RFPResponse {
  id           String    @id @default(cuid())
  userId       String
  title        String
  clientName   String?
  deadline     DateTime?
  rawContent   String    @db.Text
  // requirements: Array<{ id, category, priority, text, response?, status, confidence? }>
  requirements Json      @default("[]")
  status       String    @default("draft") // draft | in_progress | submitted
  accountId    String?
  dealId       String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([userId, createdAt])
}

// =============== Chat Sessions (Module 10) ===============

model ChatSession {
  id        String   @id @default(cuid())
  userId    String
  title     String
  // messages: Array<{ role: 'user'|'assistant', content, createdAt, citations?: string[] }>
  messages  Json     @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, updatedAt])
}

// =============== Competitor Intel (Module 7) ===============

model Competitor {
  id           String             @id @default(cuid())
  name         String
  vendor       String?            // HPE | Dell | IBM | Palo Alto | CrowdStrike | Microsoft | Other
  website      String?
  strengths    String?            @db.Text
  weaknesses   String?            @db.Text
  pricing      String?            @db.Text
  notes        String?            @db.Text
  swotAnalysis String?            @db.Text
  swotAt       DateTime?
  ownerId      String
  intel        CompetitorIntel[]
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([ownerId, createdAt])
}

model CompetitorIntel {
  id           String     @id @default(cuid())
  competitorId String
  competitor   Competitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)
  type         String     // news | pricing | win_against | loss_to | rumor | feature
  content      String     @db.Text
  source       String?
  impact       String?    // high | medium | low
  userId       String
  createdAt    DateTime   @default(now())

  @@index([competitorId, createdAt])
}

// =============== Market Sizing (Module 8) ===============

model MarketSizing {
  id         String   @id @default(cuid())
  userId     String
  title      String
  segment    String   // e.g., "Enterprise Cybersecurity"
  region     String   // e.g., "Vietnam", "HCMC"
  vertical   String?  // finance | manufacturing | retail | government | healthcare
  inputs     Json     // { assumptions, drivers, avgDealSize, penetration, etc. }
  tam        Float    // Total addressable (VND)
  sam        Float    // Serviceable addressable
  som        Float    // Serviceable obtainable
  analysis   String   @db.Text
  createdAt  DateTime @default(now())

  @@index([userId, createdAt])
}

// =============== Audit Log (Batch 3) ===============
// Every mutation on money-touching entities (deal, quotation, proposal) flows
// through logAudit() which writes a row here. Used by admin UI to see who
// did what. Keep fields minimal — don't store full snapshots, only the diff
// or action kind. If we later need full history, promote to a per-entity
// history table.

model AuditLog {
  id         String   @id @default(cuid())
  userId     String   // actor
  userEmail  String   // denormalized at write time so deleted users still show
  userRole   String
  action     String   // create | update | delete | status_change | send | export
  entity     String   // deal | quotation | proposal | account | user | product
  entityId   String?
  summary    String   // human-readable one-liner, e.g. "Deal stage: qualification → proposal"
  meta       Json?    // optional extra (before/after, ip, etc.)
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([entity, entityId])
  @@index([userId, createdAt])
}

model Quotation {
  id          String    @id @default(cuid())
  number      String    @unique // QT-2026-0001
  title       String
  accountId   String?
  dealId      String?
  ownerId     String
  currency    String    @default("VND")
  // items: Array<{ id, productId?, name, description?, vendor?, qty, unitPrice, discount (%), lineTotal }>
  items       Json      @default("[]")
  subtotal    Float     @default(0)
  discount    Float     @default(0) // overall %
  tax         Float     @default(10) // VAT 10%
  total       Float     @default(0)
  notes       String?   @db.Text
  status      String    @default("draft") // draft | sent | accepted | rejected | expired
  validUntil  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([ownerId, createdAt])
  @@index([accountId])
}
